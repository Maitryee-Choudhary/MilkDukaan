rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: consumers
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - address: string (optional, 0-200 chars)
    //   - defaultQuantity: number (required, positive)
    //   - defaultMilkType: string (optional)
    //   - defaultPrice: number (optional, positive)
    //   - active: boolean (required)
    //   - uid: string (required, matches owner)
    //
    // Collection: deliveries
    // Document ID: auto-generated
    // Fields:
    //   - consumerId: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - quantity: number (required, positive)
    //   - milkType: string (required)
    //   - status: string (required, 'delivered' | 'skipped')
    //   - pricePerUnit: number (required, positive)
    //   - uid: string (required, matches owner)
    //
    // Collection: inventory
    // Document ID: auto-generated
    // Fields:
    //   - date: string (required, YYYY-MM-DD)
    //   - type: string (required, 'buy' | 'sell')
    //   - quantity: number (required, positive)
    //   - source: string (optional)
    //   - totalAmount: number (required, positive)
    //   - uid: string (required, matches owner)
    //
    // Collection: settings
    // Document ID: user UID
    // Fields:
    //   - pricePerLitre: number (required, positive)
    //   - uid: string (required, matches owner)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in resource.data) || !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidConsumer(data) {
      return hasOnlyAllowedFields(['name', 'address', 'defaultQuantity', 'defaultMilkType', 'defaultPrice', 'active', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             data.defaultQuantity is number && data.defaultQuantity >= 0 &&
             (!('defaultMilkType' in data) || (data.defaultMilkType is string)) &&
             (!('defaultPrice' in data) || (data.defaultPrice is number && data.defaultPrice >= 0)) &&
             data.active is bool &&
             data.uid == request.auth.uid;
    }

    function isValidDelivery(data) {
      return hasOnlyAllowedFields(['consumerId', 'date', 'quantity', 'milkType', 'status', 'pricePerUnit', 'uid']) &&
             data.consumerId is string &&
             isValidDateString(data.date) &&
             data.quantity is number && data.quantity >= 0 &&
             data.milkType is string &&
             data.status in ['delivered', 'skipped'] &&
             data.pricePerUnit is number && data.pricePerUnit >= 0 &&
             data.uid == request.auth.uid;
    }

    function isValidInventory(data) {
      return hasOnlyAllowedFields(['date', 'type', 'quantity', 'source', 'totalAmount', 'uid']) &&
             isValidDateString(data.date) &&
             data.type in ['buy', 'sell'] &&
             data.quantity is number && data.quantity >= 0 &&
             (!('source' in data) || (data.source is string && data.source.size() <= 100)) &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.uid == request.auth.uid;
    }

    function isValidSettings(data) {
      return data.pricePerLitre is number && data.pricePerLitre >= 0 &&
             (!('language' in data) || (data.language in ['en', 'hi'])) &&
             (!('milkTypes' in data) || (data.milkTypes is list)) &&
             (!('uid' in data) || (data.uid == request.auth.uid));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /consumers/{consumerId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidConsumer(request.resource.data);
      allow update: if isDocOwner() && isValidConsumer(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /deliveries/{deliveryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidDelivery(request.resource.data);
      allow update: if isDocOwner() && isValidDelivery(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /inventory/{inventoryId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidInventory(request.resource.data);
      allow update: if isDocOwner() && isValidInventory(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /settings/{settingsId} {
      allow read: if isOwner(settingsId);
      allow create: if isOwner(settingsId) && isValidSettings(request.resource.data);
      allow update: if isOwner(settingsId) && isValidSettings(request.resource.data);
      allow delete: if isOwner(settingsId);
    }
  }
}
